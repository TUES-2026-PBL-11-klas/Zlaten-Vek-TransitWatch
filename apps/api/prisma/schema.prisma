generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  credibilityScore Int      @default(0) @map("credibility_score")
  createdAt        DateTime @default(now()) @map("created_at")
  reports          Report[]
  votes            Vote[]

  @@map("users")
}

model Line {
  id        String     @id @default(uuid())
  gtfsId    String?    @unique @map("gtfs_id")
  name      String
  type      String // bus | tram | metro | trolley
  color     String?    // route color from GTFS (hex without #)
  lineStops LineStop[]
  reports   Report[]
  shape     Shape?

  @@map("lines")
}

model Stop {
  id        String     @id @default(uuid())
  gtfsId    String?    @unique @map("gtfs_id")
  stopCode  String?    @map("stop_code")
  name      String
  lat       Float
  lng       Float
  lineStops LineStop[]

  @@index([lat, lng])
  @@index([stopCode])
  @@map("stops")
}

model LineStop {
  id        String @id @default(uuid())
  lineId    String @map("line_id")
  stopId    String @map("stop_id")
  stopOrder Int    @default(0) @map("stop_order")
  line      Line   @relation(fields: [lineId], references: [id], onDelete: Cascade)
  stop      Stop   @relation(fields: [stopId], references: [id], onDelete: Cascade)

  @@unique([lineId, stopId, stopOrder])
  @@index([lineId])
  @@index([stopId])
  @@map("line_stops")
}

model Report {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  lineId           String   @map("line_id")
  vehicleId        String?  @map("vehicle_id")
  category         String
  description      String?
  photoUrl         String?  @map("photo_url")
  credibilityScore Int      @default(5) @map("credibility_score")
  expiresAt        DateTime @map("expires_at")
  status           String   @default("active")
  createdAt        DateTime @default(now()) @map("created_at")
  user             User     @relation(fields: [userId], references: [id])
  line             Line     @relation(fields: [lineId], references: [id])
  votes            Vote[]

  @@map("reports")
}

model Vote {
  id       String @id @default(uuid())
  reportId String @map("report_id")
  userId   String @map("user_id")
  type     String // confirm | dispute
  report   Report @relation(fields: [reportId], references: [id])
  user     User   @relation(fields: [userId], references: [id])

  @@unique([reportId, userId])
  @@map("votes")
}

model Shape {
  id          String @id @default(uuid())
  lineId      String @unique @map("line_id")
  coordinates Json // Array of [lat, lng] coordinate pairs, simplified with RDP
  line        Line   @relation(fields: [lineId], references: [id], onDelete: Cascade)

  @@map("shapes")
}
