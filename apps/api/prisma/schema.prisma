generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @db.Uuid
  email           String   @unique
  credibilityScore Int     @default(0) @map("credibility_score")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("users")
}
